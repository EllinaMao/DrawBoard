@model DrawBoard.Models.Message

@{
	ViewData["Title"] = "Общий чат";
}

<div class="container mt-5">
	<div class="row">
		<div class="col-md-8 offset-md-2">
			<h2 class="text-center mb-4">@ViewData["Title"]</h2>

			<div class="card">
				<div class="card-body">
					<div id="chatroom" class="border rounded p-3 mb-3 bg-light overflow-auto" style="height: 40vh;">
						<!-- Сообщения-->
					</div>

					<div class="mb-3">
						<input asp-for="Sender" id="userName" class="form-control" placeholder="Ваше имя" />
						<span asp-validation-for="Sender" class="text-danger"></span>
					</div>

					<div class="input-group">
						<input asp-for="Content" id="message" class="form-control" placeholder="Введите сообщение..." />
						<button class="btn btn-primary" id="sendBtn" type="button" disabled>Отправить</button>
					</div>
					<span asp-validation-for="Content" class="text-danger"></span>
				</div>
			</div>
		</div>
	</div>
</div>

@section Scripts {
	<partial name="_ValidationScriptsPartial" />
	<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/5.0.11/signalr.min.js"></script>
	<script src="~/js/chat.js"></script>
	<script src="~/js/hub.js"></script>
}